#!/bin/bash
# preinstall — runs BEFORE files are copied by the .pkg installer
# Checks: macOS version, disk space, Python availability, internet
set -e

INSTALL_PATH="/Applications/MagicClick"
MIN_FREE_GB=3
LOG="/tmp/magic_click_preinstall.log"

log() { echo "[$(date '+%H:%M:%S')] $*" | tee -a "$LOG"; }
fail() { log "FATAL: $*"; exit 1; }

log "=== Magic Click Pre-Install Check ==="
log "macOS: $(sw_vers -productVersion)"

# macOS >= 12 check
MACOS_MAJOR=$(sw_vers -productVersion | cut -d. -f1)
[ "$MACOS_MAJOR" -ge 12 ] || fail "macOS 12 (Monterey) or newer required. You have $(sw_vers -productVersion)."
log "✓ macOS version OK"

# Python 3.10 to 3.12 check (ML libraries like mediapipe lack wheels for 3.13+)
check_py_version() {
    local py="$1"
    local ver=$("$py" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || echo "0.0")
    local major=$(echo "$ver" | cut -d. -f1)
    local minor=$(echo "$ver" | cut -d. -f2)
    if [ "$major" -eq 3 ] && [ "$minor" -ge 10 ] && [ "$minor" -le 12 ]; then
        return 0
    fi
    return 1
}

find_python() {
    # 1. Check PATH
    local py=$(command -v python3 2>/dev/null || command -v python 2>/dev/null)
    if [ -n "$py" ] && check_py_version "$py"; then echo "$py"; return 0; fi
    
    # 2. Check standard python.org installs (latest supported ML version first)
    for v in 3.12 3.11 3.10; do
        local p="/Library/Frameworks/Python.framework/Versions/$v/bin/python3"
        if [ -x "$p" ] && check_py_version "$p"; then echo "$p"; return 0; fi
    done
    
    # 3. Check Homebrew (Apple Silicon then Intel)
    for p in "/opt/homebrew/bin/python3" "/usr/local/bin/python3"; do
        if [ -x "$p" ] && check_py_version "$p"; then echo "$p"; return 0; fi
    done
    
    return 1
}

PYTHON=$(find_python)
if [ -z "$PYTHON" ]; then
    osascript -e 'display alert "Compatible Python Not Found" message "Magic Click requires Python 3.10, 3.11, or 3.12.\n\nNewer versions (like 3.13 or 3.14) are not supported because AI libraries do not yet have stable builds for them.\n\nPlease install Python 3.11 from:\nhttps://www.python.org/downloads/\n\nThen run the installer again." as critical'
    fail "Python >= 3.10 and <= 3.12 not found in PATH or standard locations"
fi

PY_VER=$("$PYTHON" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
log "✓ Python $PY_VER OK ($PYTHON)"

# Disk space check
FREE_BYTES=$(df -k "$HOME" | awk 'NR==2 {print $4}')
FREE_GB=$(echo "scale=1; $FREE_BYTES / 1048576" | bc 2>/dev/null || echo "10")
if (( $(echo "$FREE_GB < $MIN_FREE_GB" | bc -l) )); then
    osascript -e "display alert \"Not Enough Disk Space\" message \"Magic Click requires at least ${MIN_FREE_GB} GB of free space.\n\nYou have ${FREE_GB} GB available.\n\nPlease free up some space and try again.\" as critical"
    fail "Insufficient disk space: ${FREE_GB} GB free"
fi
log "✓ Disk space OK (${FREE_GB} GB free)"

# Internet connectivity check
if ! nc -zw3 8.8.8.8 53 2>/dev/null; then
    CHOICE=$(osascript -e 'button returned of (display alert "No Internet Connection" message "Magic Click needs internet access for one-time setup to download AI models (~500 MB).\n\nPlease connect to Wi-Fi or Ethernet and try again." buttons {"Cancel", "Continue Anyway"} default button "Cancel")')
    [ "$CHOICE" = "Continue Anyway" ] || fail "No internet — user cancelled"
    log "⚠ No internet — user chose to continue anyway"
else
    log "✓ Internet OK"
fi

# Remove quarantine from existing install if upgrading
if [ -d "$INSTALL_PATH" ]; then
    xattr -dr com.apple.quarantine "$INSTALL_PATH" 2>/dev/null || true
    log "✓ Quarantine cleared from existing install"
fi

log "=== Pre-install checks passed ==="
exit 0
