#!/bin/bash
# postinstall — runs AFTER files are copied by the .pkg installer
# Launches installer_bootstrap.py to set up the venv and dependencies
set -e

# Fix for "clang++: error: unable to make temporary file" during pip C++ compilation
# The macOS Installer sandbox restricts standard temp directories for the root user.
export TMPDIR=/tmp
export TMP=/tmp
export TEMP=/tmp

INSTALL_PATH="/Applications/MagicClick"
LOG="/tmp/magic_click_postinstall.log"

log() { echo "[$(date '+%H:%M:%S')] $*" | tee -a "$LOG"; }

log "=== Magic Click Post-Install ==="
log "Install path: $INSTALL_PATH"

# Strip quarantine from all installed files
xattr -dr com.apple.quarantine "$INSTALL_PATH" 2>/dev/null || true
log "✓ Quarantine attribute cleared"

# Make all shell scripts executable
chmod +x "$INSTALL_PATH/launchers/macos/MagicClick.command" 2>/dev/null || true
chmod +x "$INSTALL_PATH/launchers/macos/build_app.sh" 2>/dev/null || true
chmod +x "$INSTALL_PATH/launchers/linux/install.sh" 2>/dev/null || true
chmod +x "$INSTALL_PATH/installers/macos/scripts/"* 2>/dev/null || true

# Find python3 (installer runs as root with restricted PATH)
# Limit to 3.12 because ML libraries lack wheels for 3.13/3.14
check_py_version() {
    local py="$1"
    local ver=$("$py" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || echo "0.0")
    local major=$(echo "$ver" | cut -d. -f1)
    local minor=$(echo "$ver" | cut -d. -f2)
    if [ "$major" -eq 3 ] && [ "$minor" -ge 10 ] && [ "$minor" -le 12 ]; then return 0; fi
    return 1
}

# Detect hardware architecture (arm64 = Apple Silicon)
HW_ARCH=$(uname -m)

native_python_for_arch() {
    # Returns 0 only if the given Python binary runs natively on this CPU.
    # On Apple Silicon we reject x86_64-only binaries (Rosetta).
    local py="$1"
    if [ "$HW_ARCH" = "arm64" ]; then
        local py_arch
        py_arch=$(python3 -c "import platform; print(platform.machine())" 2>/dev/null || echo "unknown")
        arch="$py_arch" "$py" -c "import platform; m=platform.machine(); exit(0 if m=='arm64' else 1)" 2>/dev/null
        return $?
    fi
    return 0   # on Intel, any x86_64 Python is fine
}

find_python() {
    # On Apple Silicon: prefer Homebrew (native arm64) Python first
    if [ "$HW_ARCH" = "arm64" ]; then
        for p in "/opt/homebrew/bin/python3.12" "/opt/homebrew/bin/python3.11" "/opt/homebrew/bin/python3.10" "/opt/homebrew/bin/python3"; do
            if [ -x "$p" ] && check_py_version "$p" && native_python_for_arch "$p"; then
                echo "$p"; return 0
            fi
        done
    fi
    # Universal fallback: Framework Python (works on Intel; on Apple Silicon this
    # is Rosetta but acceptable if Homebrew isn't installed)
    for v in 3.12 3.11 3.10; do
        local p="/Library/Frameworks/Python.framework/Versions/$v/bin/python3"
        if [ -x "$p" ] && check_py_version "$p"; then echo "$p"; return 0; fi
    done
    for p in "/usr/local/bin/python3" "$(command -v python3 2>/dev/null)"; do
        if [ -n "$p" ] && [ -x "$p" ] && check_py_version "$p"; then echo "$p"; return 0; fi
    done
    return 1
}

PYTHON=$(find_python)
[ -n "$PYTHON" ] || { log "FATAL: Python >= 3.10 and <= 3.12 not found"; exit 1; }
log "Using Python: $PYTHON (arch: $("$PYTHON" -c 'import platform; print(platform.machine())' 2>/dev/null || echo unknown))"

# Build the .app bundle
log "▶  Building MagicClick.app…"
cd "$INSTALL_PATH"
bash launchers/macos/build_app.sh >> "$LOG" 2>&1 || log "⚠ .app build had warnings (non-fatal)"
log "✓ MagicClick.app ready"

# Copy .app to /Applications root for easy access
APP_SRC="$INSTALL_PATH/launchers/macos/MagicClick.app"
APP_DEST="/Applications/MagicClick.app"
if [ -d "$APP_SRC" ]; then
    cp -R "$APP_SRC" "$APP_DEST" 2>/dev/null || true
    xattr -dr com.apple.quarantine "$APP_DEST" 2>/dev/null || true
    log "✓ MagicClick.app copied to /Applications/"
fi

# Launch installer_bootstrap.py in the background (shows premium GUI)
log "▶  Launching installer_bootstrap.py…"
"$PYTHON" "$INSTALL_PATH/installers/installer_bootstrap.py" \
    >> "$LOG" 2>&1 &

log "=== Post-install script complete (bootstrap running in background) ==="
exit 0
